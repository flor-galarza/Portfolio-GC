---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import { siteMeta } from "../data/content";
---

<BaseLayout title={`Contacto | ${siteMeta.teamName}`} description={`Reflexión final y enlaces de cierre de ${siteMeta.teamName}.`}>
  <section class="page-section hero-small">
    <div class="container">
      <p class="eyebrow">Contacto</p>
      <h1>Cierre del equipo</h1>
      <p>Espacio editable para dejar reflexión final y enlaces relevantes para docentes y pares.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="container split-grid">
      <Card title="Reflexión final del equipo">
        <p>Reflexión final aquí.</p>
      </Card>

      <Card title="Links útiles">
        <ul class="clean-list">
          <li><a href="#">Link 1</a></li>
          <li><a href="#">Link 2</a></li>
        </ul>
      </Card>
    </div>
  </section>
</BaseLayout>
