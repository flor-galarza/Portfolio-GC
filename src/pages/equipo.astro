---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import Badge from "../components/Badge.astro";
import { teamMembers } from "../data/content";
---

<BaseLayout title="Equipo | Portfolio UTN" description="Equipo, roles y competencias.">
  <section class="page-section hero-small">
    <div class="container">
      <p class="eyebrow">Equipo</p>
      <h1>Personas que impulsan el portfolio</h1>
      <p>Perfiles resumidos con informacion editable para la entrega final.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="container card-grid">
      {teamMembers.map((member) => (
        <Card title={member.name} subtitle={member.role}>
          <img src={member.avatar} alt={`Avatar de ${member.name}`} class="avatar" loading="lazy" width="120" height="120" />
          <p class="stack-sm">Competencias clave:</p>
          <div class="badge-row">
            {member.competencies.map((competency) => (
              <Badge label={competency} />
            ))}
          </div>
        </Card>
      ))}
    </div>
  </section>
</BaseLayout>
