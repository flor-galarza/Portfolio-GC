---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import TeamMemberCard from "../components/TeamMemberCard.astro";
import { siteMeta, teamMembers, teamSectionDescription } from "../data/content";
---

<BaseLayout
  title={`Equipo | ${siteMeta.teamName}`}
  description={`Equipo, roles, fortalezas, intereses y competencias del portfolio de ${siteMeta.teamName}.`}
>
  <PageHero
    eyebrow="Equipo"
    title="Personas que convierten el proceso en una entrega profesional"
    description={teamSectionDescription}
    actions={[
      { href: "/rpa", label: "Ver RPA" },
      { href: "/", label: "Volver al inicio", variant: "secondary" }
    ]}
    compact
  />

  <section class="page-section section-shell">
    <div class="container card-grid card-grid--profiles-lg">
      {teamMembers.map((member) => (
        <TeamMemberCard member={member} />
      ))}
    </div>
  </section>
</BaseLayout>
