---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import { rpaRoutes } from "../data/content";
---

<BaseLayout title="RPA | Portfolio UTN" description="Ruta personal de aprendizaje de cada integrante.">
  <section class="page-section hero-small">
    <div class="container">
      <p class="eyebrow">RPA</p>
      <h1>Rutas personales de aprendizaje</h1>
      <p>Cada integrante documenta su evolucion y foco profesional.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="container card-grid">
      {rpaRoutes.map((route) => (
        <Card title={route.member} subtitle="Itinerario individual">
          <ol class="clean-list ordered">
            {route.route.map((step) => (
              <li>{step}</li>
            ))}
          </ol>
        </Card>
      ))}
    </div>
  </section>
</BaseLayout>
