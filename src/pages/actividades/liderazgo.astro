---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import Card from "../../components/Card.astro";
import { siteMeta } from "../../data/content";
import camiImage from "../../assets/liderazgo/cami.jpeg";
import fabriImage from "../../assets/liderazgo/fabri.jpeg";
import brunoImage from "../../assets/liderazgo/bruno.jpeg";
import florImage from "../../assets/liderazgo/flor.jpeg";
import renImage from "../../assets/liderazgo/ren.png";

interface TeamMemberTest {
  name: string;
  image?: string;
  tests: {
    test1: string;
    test2: string;
    test3: string;
  };
}

const teamMembers: TeamMemberTest[] = [
  {
    name: "Camila Zeniquel",
    image: camiImage.src,
    tests: {
      test1: "Líder Social",
      test2: "Democrático",
      test3: "Democrático"
    }
  },
  {
    name: "Fabricio Jerez",
    image: fabriImage.src,
    tests: {
      test1: "Líder de equipo",
      test2: "Integrador",
      test3: "Democrático"
    }
  },
  {
    name: "Renzo Urturi",
    image: renImage.src,
    tests: {
      test1: "Líder de Equipo",
      test2: "Visionario",
      test3: "Democrático"
    }
  },
  {
    name: "Bruno Rivero",
    image: brunoImage.src,
    tests: {
      test1: "Autoritario",
      test2: "Democrático",
      test3: "Democrático"
    }
  },
  {
    name: "Florencia Galarza Maumary",
    image: florImage.src,
    tests: {
      test1: "Líder de equipo",
      test2: "Democrático",
      test3: "Democrático"
    }
  }
];
---

<BaseLayout title={`Tests de Liderazgo | ${siteMeta.teamName}`} description={`Resultados de tests de liderazgo del equipo ${siteMeta.teamName}`}>
  <PageHero
    eyebrow="Tests de Liderazgo"
    title="Resultados de evaluaciones de liderazgo"
    description="Recopilación de los resultados de los diferentes tests de liderazgo realizados durante el proyecto"
    compact
  />

  <section class="page-section section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="Equipo"
        title="Resultados por integrante"
        description="A continuación se muestran los resultados de los tres tests de liderazgo tomados por cada miembro del equipo."
      />

      <div class="card-grid">
        {teamMembers.map((member) => (
          <Card title={member.name} subtitle="Resultados de tests">
            <div class="leadership-card-content">
              {member.image && (
                <div class="member-image-container">
                  <img 
                    src={member.image} 
                    alt={member.name}
                    class="member-image"
                  />
                </div>
              )}
              
              <div class="tests-results">
                <div class="test-item">
                  <h4 class="test-label">Test 1</h4>
                  <p>{member.tests.test1}</p>
                </div>
                
                <div class="test-item">
                  <h4 class="test-label">Test 2</h4>
                  <p>{member.tests.test2}</p>
                </div>
                
                <div class="test-item">
                  <h4 class="test-label">Test 3</h4>
                  <p>{member.tests.test3}</p>
                </div>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .leadership-card-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .member-image-container {
    overflow: hidden;
    border-radius: var(--radius-lg);
    width: 100%;
    height: auto;
  }

  .member-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .tests-results {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .test-item {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
  }

  .test-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 0.25rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .test-item p {
    margin: 0;
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.5;
  }
</style>
