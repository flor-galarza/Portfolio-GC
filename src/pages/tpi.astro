---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import EvidenceList from "../components/EvidenceList.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { challengeContent, siteMeta, tpiContent } from "../data/content";
---

<BaseLayout title={`TPI | ${siteMeta.teamName}`} description={`Trabajo Práctico Integrador del equipo ${siteMeta.teamName}.`}>
  <PageHero
    eyebrow="TPI"
    title="Trabajo Práctico Integrador"
    description={tpiContent.description}
    actions={[
      { href: "/", label: "Volver al inicio", variant: "secondary" }
    ]}
    compact
  />

  <!-- Sección: Propósito y Metodología -->
  <section class="page-section section-shell">
    <div class="container split-grid split-grid--feature">
      <Card title="Consigna del TPI" subtitle="Qué se busca lograr">
        <p>
          Realizar una actividad de aprendizaje significativo mediante el análisis de una organización real a partir de un problema organizacional, aplicando herramientas, metodologías y técnicas de gestión.
        </p>
      </Card>
      <Card title="Metodología" subtitle="Cómo se desarrolla el trabajo">
        <p>
          El desarrollo del TPI se realiza mediante trabajo colaborativo, permitiendo evaluar la participación activa de cada integrante del equipo en la resolución integral del proyecto.
        </p>
      </Card>
    </div>
  </section>

  <!-- Sección: Organización Estudiada -->
  <section class="page-section section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="Caso de Estudio"
        title="Organización Esnal Seguros"
        description="Productores Asesores de Seguros - Análisis organizacional de la empresa"
      />
      <div class="split-grid split-grid--feature">
        <Card title="Información de la Organización" subtitle="Datos de ubicación y contacto">
          <div class="organization-info">
            <div class="info-group">
              <strong>Razón Social:</strong>
              <p>Organización Esnal Seguros</p>
            </div>
            <div class="info-group">
              <strong>Rubro:</strong>
              <p>Productores Asesores de Seguros</p>
            </div>
            <div class="info-group">
              <strong>Domicilio:</strong>
              <p>Formosa 82</p>
            </div>
            <div class="info-group">
              <strong>Localidad:</strong>
              <p>Resistencia, San Fernando</p>
            </div>
            <div class="info-group">
              <strong>Provincia:</strong>
              <p>Chaco</p>
            </div>
          </div>
        </Card>
        <div class="map-container">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3534.5825831246287!2d-58.979157!3d-27.467!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x944e6bdca79a9d5f%3A0xf4f4f4f4f4f4f4f4!2sFormosa%2082%2C%20Resistencia%2C%20Chaco%2C%20Argentina!5e0!3m2!1ses!2sar!4v1715000000000" 
            width="100%" 
            height="400" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Organización Esnal Seguros"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="Evidencias del TPI"
        title="Documentación y entregables del TPI"
        description="Acceso directo a las evidencias del proyecto, incluyendo el diagnóstico inicial, el plan de trabajo principal y la infografía gráfica general."
      />
      <EvidenceList items={tpiContent.evidences} />
    </div>
  </section>
</BaseLayout>
