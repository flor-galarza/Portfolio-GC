---
import BaseLayout from "../layouts/BaseLayout.astro";
import Badge from "../components/Badge.astro";
import Card from "../components/Card.astro";
import ConceptMapCard from "../components/ConceptMapCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import TeamMemberCard from "../components/TeamMemberCard.astro";
import Timeline from "../components/Timeline.astro";
import {
  challengeContent,
  conceptLevels,
  heroHighlights,
  presentationVideo,
  quickFacts,
  siteMeta,
  teamIntro,
  teamMembers,
  teamSectionDescription,
  timelineItems,
  tpiContent
} from "../data/content";
import teamLogo from "../assets/logo.png";
---

<BaseLayout title={`Home | ${siteMeta.teamName}`} description={siteMeta.description}>
  <section class="page-section hero">
    <div class="container hero-grid hero-grid--enhanced">
      <div class="hero-copy reveal-up" data-reveal>
        <p class="eyebrow">Identificación del equipo</p>
        <h1>{siteMeta.teamName}</h1>
          <p class="hero-lead">
          Sitio web multipágina, profesional y responsive de {siteMeta.teamName} con el desafío D3 desarrollado,
          las etapas D4 a D7 preparadas como próximas entregas, rutas personales de aprendizaje, mapas conceptuales y TPI en una sola narrativa.
          </p>
        <div class="badge-row">
          <Badge label="Modo oscuro" />
          <Badge label="Responsive" />
          <Badge label="TPI conectado" />
          <Badge label="Placeholders listos" />
        </div>
        <div class="hero-actions">
          <a class="button button-primary" href="/desafios">Explorar desafíos</a>
          <a class="button button-secondary" href="/equipo">Conocer al equipo</a>
        </div>
        {/* Cuadros de heroHighlights eliminados */}
      </div>

      <div class="hero-visual reveal-up" data-reveal>
        <div class="logo-panel logo-panel--hero no-bg no-shadow">
          <div class="orbital-ring orbital-ring-a" aria-hidden="true"></div>
          <div class="orbital-ring orbital-ring-b" aria-hidden="true"></div>
          <img src={teamLogo.src} alt={siteMeta.logoAlt} width="400" height="400" loading="eager" decoding="async" />
        </div>
        {/* Cuadros de quickFacts eliminados */}
      </div>
    </div>
  </section>

  <section class="page-section section-shell">
    <div class="container split-grid split-grid--feature">
      <Card title="Identidad del equipo" subtitle="Quiénes somos y cómo trabajamos">
        <p>
          {teamIntro}
        </p>
      </Card>
      <Card title="Contenido vinculado al TPI" subtitle="Una narrativa integrada, no secciones aisladas">
        <p>{tpiContent.focus}</p>
      </Card>
    </div>
  </section>

  <section class="page-section section-shell">
    <div class="container">
        <SectionHeader
          eyebrow="Integrantes"
          title="Perfiles individuales con rol, intereses y competencias"
          description={teamSectionDescription}
        />
      <div class="card-grid card-grid--profiles">
        {teamMembers.map((member) => (
          <TeamMemberCard member={member} compact />
        ))}
      </div>
    </div>
  </section>

  <section class="page-section section-shell">
    <div class="container split-grid split-grid--feature">
      <Card title={presentationVideo.title} subtitle="Video de presentación del equipo">
        <div class="video-wrap">
          <iframe
            src={presentationVideo.embedUrl}
            title={presentationVideo.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
        <p class="support-note">{presentationVideo.note}</p>
      </Card>

      <Card title="Accesos a los desafíos" subtitle="D3 disponible hoy y D4-D7 listos para completarse más adelante">
        <div class="challenge-link-grid">
          {challengeContent.map((challenge) => (
            <a class="challenge-link-card" href={`/desafios/${challenge.slug}`}>
              <span>{challenge.code}</span>
              <strong>{challenge.title}</strong>
              <small>{challenge.summary}</small>
              <small>{challenge.status === "available" ? "Contenido publicado" : "Próximamente"}</small>
            </a>
          ))}
        </div>
      </Card>
    </div>
  </section>

  <section class="page-section section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="RPA por integrante"
        title="La evolución individual que sostiene el recorrido colectivo"
        description="Las rutas personales de aprendizaje muestran cómo cada integrante desarrolló intereses y competencias aplicadas al sitio y al TPI."
      />
      <div class="card-grid card-grid--rpa">
        {teamMembers.map((member) => (
          <Card title={member.name} subtitle={member.role}>
            <ol class="clean-list ordered clean-list--tight">
              {member.rpa.map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="Proceso"
        title="Cronología del aprendizaje del equipo"
        description="Los hitos muestran el avance actual de la primera semana y dejan visibles las próximas etapas sin anticipar contenido inexistente."
      />
      <Timeline items={timelineItems} />
    </div>
  </section>

  <section class="page-section section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="Mapa conceptual"
        title="Un mapa por nivel, claro y fácil de reemplazar"
        description="Cada nivel ordena conceptos del proyecto y deja una base visual elegante para incorporar versiones finales gráficas o interactivas."
      />
      <div class="card-grid card-grid--concepts">
        {conceptLevels.map((level) => (
          <ConceptMapCard level={level} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
