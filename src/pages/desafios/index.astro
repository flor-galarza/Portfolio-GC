---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { challengeContent, siteMeta } from "../../data/content";
---

<BaseLayout title={`Desafíos | ${siteMeta.teamName}`} description={`Recorrido de ${siteMeta.teamName}: D3 disponible y D4 a D7 preparados como próximas etapas.`}>
  <PageHero
    eyebrow="Desafíos"
    title="Recorrido D3 a D7"
    description="Desafíos completados y próximos a completar"
    actions={[
      { href: "/", label: "Ir al inicio", variant: "secondary" }
    ]}
    compact
  />

  <section class="page-section section-shell">
    <div class="container">
      <SectionHeader
        eyebrow ="Nuestra bitácora de trabajo"
        title="Detalle de desafíos"
        description="Un recorrido por los desafíos técnicos superados y las competencias desarrolladas en cada etapa del cuatrimestre."
      />
        <div class="card-vertical">
          {challengeContent.map((challenge) => (
            <Card title={`${challenge.code} · ${challenge.title}`} subtitle="Página individual">
              <p>{challenge.summary}</p>
              {challenge.status === "available" && challenge.evidences.length > 0 && challenge.evidences[0].href && (
                <p>
                  <a href={challenge.evidences[0].href} class="link-cta" target="_blank" rel="noopener noreferrer">
                    {challenge.code === "D4" ? "Abrir hoja de cálculo" : "Ver evidencia"}
                  </a>
                </p>
              )}
              <div class="badge-row challenge-inline-badges">
                <span class="badge">{challenge.status === "available" ? "Disponible" : "Próximamente"}</span>
                {challenge.status === "available" && challenge.competenciesDeveloped.map((item) => (
                  <span class="badge">{item}</span>
                ))}
              </div>
            </Card>
          ))}
        </div>
    </div>
  </section>
</BaseLayout>
