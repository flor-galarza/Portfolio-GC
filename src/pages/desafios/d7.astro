---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChallengeTemplate from "../../components/ChallengeTemplate.astro";
import { getChallengeBySlug, siteMeta } from "../../data/content";

const challenge = getChallengeBySlug("d7");
---

<BaseLayout title={`D7 | ${siteMeta.teamName}`} description={`Desafío D7 de ${siteMeta.teamName}.`}>
  {challenge && <ChallengeTemplate challenge={challenge} />}
</BaseLayout>
