---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChallengeTemplate from "../../components/ChallengeTemplate.astro";
import { getChallengeBySlug, siteMeta } from "../../data/content";

const challenge = getChallengeBySlug("d5");
---

<BaseLayout title={`D5 | ${siteMeta.teamName}`} description={`Desafío D5 de ${siteMeta.teamName}.`}>
  {challenge && <ChallengeTemplate challenge={challenge} />}
</BaseLayout>
