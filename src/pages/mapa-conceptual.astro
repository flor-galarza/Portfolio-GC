---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteMeta } from "../data/content";
import mapaMentalPdf from "../assets/Mapa.pdf";
---

<BaseLayout
  title={`Mapa conceptual | ${siteMeta.teamName}`}
  description={`Mapa mental completo de la materia para ${siteMeta.teamName}.`}
>
  <section class="page-section section-shell">
    <div class="container">
      <article class="pdf-card reveal-up" data-reveal>
        <div class="pdf-card__header">
          <div>
            <p class="concept-level">Mapa mental</p>
            <h1>Materia completa</h1>
            <p>
              Reemplazamos los mapas anteriores por la versión final en PDF para que el contenido se
              vea completo en una sola página.
            </p>
          </div>
          <a class="pdf-card__link" href={mapaMentalPdf} target="_blank" rel="noreferrer">
            Abrir PDF
          </a>
        </div>

        <div class="pdf-viewer" aria-label="Mapa mental completo de la materia">
          <iframe
            src={`${mapaMentalPdf}#view=FitH`}
            title="Mapa mental completo de la materia"
            loading="lazy"
          ></iframe>
        </div>

        <p class="pdf-card__fallback">
          Si tu navegador no muestra el PDF correctamente, podés
          <a href={mapaMentalPdf} target="_blank" rel="noreferrer">abrirlo en una pestaña nueva</a>.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .pdf-card {
    display: grid;
    gap: 1.5rem;
    padding: clamp(1.25rem, 2vw, 2rem);
    border: 1px solid var(--line);
    border-radius: 1.5rem;
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    box-shadow: 0 24px 60px rgb(15 23 42 / 0.18);
  }

  .pdf-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .pdf-card__header h1 {
    margin-bottom: 0.5rem;
  }

  .pdf-card__header p:last-child {
    margin-bottom: 0;
    max-width: 65ch;
  }

  .pdf-card__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface-2);
    color: var(--text);
    font-weight: 700;
    text-decoration: none;
  }

  .pdf-card__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .pdf-viewer {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: #fff;
  }

  .pdf-viewer iframe {
    width: 100%;
    height: min(78vh, 980px);
    border: 0;
    display: block;
  }

  .pdf-card__fallback {
    margin: 0;
  }

  @media (max-width: 640px) {
    .pdf-viewer iframe {
      height: 70vh;
    }
  }
</style>
