---
interface Props {
  label: string;
  value: number;
}

const { label, value } = Astro.props;
const boundedValue = Math.max(0, Math.min(100, value));
---

<div class="progress-item reveal-up">
  <div class="progress-head">
    <span>{label}</span>
    <span>{boundedValue}%</span>
  </div>
  <div class="progress-track" role="progressbar" aria-valuenow={boundedValue} aria-valuemin="0" aria-valuemax="100" aria-label={label}>
    <div class="progress-fill" style={`width: ${boundedValue}%`}></div>
  </div>
</div>
