---
// LearningPath.astro
// Uso: <LearningPath units={member.learningUnits} memberAccent={member.accent} />

import type { LearningUnit } from "../../data/content";

interface Props {
  units: LearningUnit[];
  memberAccent?: "cyan" | "mint" | "violet" | "amber" | "rose";
}

const { units, memberAccent = "cyan" } = Astro.props;

const colorMap = {
  cyan:   { accent: "var(--accent)",   bg: "color-mix(in srgb, var(--accent)   18%, transparent)" },
  mint:   { accent: "var(--accent-2)",  bg: "color-mix(in srgb, var(--accent-2) 18%, transparent)" },
  violet: { accent: "var(--accent-3)",  bg: "color-mix(in srgb, var(--accent-3) 18%, transparent)" },
  amber:  { accent: "#ffc475",          bg: "rgba(255,196,117,0.18)"                               },
  rose:   { accent: "#ff89b0",          bg: "rgba(255,137,176,0.18)"                               },
};

// Cada unidad hereda el accent del miembro si no define color propio
const resolveColor = (unit: LearningUnit) =>
  colorMap[unit.color ?? memberAccent] ?? colorMap[memberAccent];

const palette = ["cyan", "mint", "violet", "amber", "rose"] as const;
---

<!-- ── Ruta de Aprendizaje ─────────────────────────────── -->
<div class="lp-wrapper" aria-label="Ruta de aprendizaje">

  <svg class="lp-svg" aria-hidden="true" preserveAspectRatio="none">
    <defs>
      <linearGradient id="lp-line-grad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%"   stop-color="var(--accent)"   stop-opacity="0.55" />
        <stop offset="50%"  stop-color="var(--accent-3)" stop-opacity="0.55" />
        <stop offset="100%" stop-color="var(--accent-2)" stop-opacity="0.55" />
      </linearGradient>
    </defs>
    <polyline id="lp-polyline" stroke="url(#lp-line-grad)" stroke-width="2.5"
              stroke-dasharray="8 7" fill="none" stroke-linecap="round" />
  </svg>

  <ol class="lp-track" role="list">
    {units.map((unit, idx) => {
      const col = resolveColor(unit);
      const side = idx % 2 === 0 ? "left" : "right";
      return (
        <li
          class={`lp-node lp-node--${side}`}
          style={`--node-accent: ${col.accent}; --node-bg: ${col.bg};`}
        >
          <button
            class="lp-bubble"
            aria-haspopup="dialog"
            aria-label={`Abrir reflexión de Unidad ${unit.id}: ${unit.title}`}
            data-modal={`lp-modal-${unit.id}`}
          >
            <span class="lp-bubble__num">{unit.id}</span>
            <span class="lp-bubble__label">{unit.title}</span>
            {unit.subtitle && (
              <span class="lp-bubble__sub">{unit.subtitle}</span>
            )}
          </button>
        </li>
      );
    })}
  </ol>
</div>

<!-- ── Modales ─────────────────────────────────────────── -->
{units.map((unit) => {
  const col = resolveColor(unit);
  return (
    <dialog
      id={`lp-modal-${unit.id}`}
      class="lp-modal"
      aria-labelledby={`lp-modal-title-${unit.id}`}
      style={`--node-accent: ${col.accent}; --node-bg: ${col.bg};`}
    >
      <div class="lp-modal__inner">

        <header class="lp-modal__header">
          <span class="lp-modal__eyebrow">Unidad {unit.id}</span>
          <h3 id={`lp-modal-title-${unit.id}`} class="lp-modal__title">{unit.title}</h3>
          {unit.subtitle && <p class="lp-modal__subtitle">{unit.subtitle}</p>}
        </header>

        <div class="lp-modal__body">

          <!-- Reflexión personal -->
          <div class="lp-modal__block">
            <p class="lp-modal__block-label">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
                <path d="M7 4v3.5l2 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              Reflexión personal
            </p>
            <p class="lp-modal__reflection">{unit.reflection}</p>
          </div>

          <!-- Conceptos nuevos adquiridos -->
          {unit.newConcepts?.length > 0 && (
            <div class="lp-modal__block">
              <p class="lp-modal__block-label">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M7 1.5v11M1.5 7h11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
                Conceptos nuevos adquiridos
              </p>
              <ul class="lp-modal__list">
                {unit.newConcepts.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          )}

          <!-- Conceptos de interés -->
          {unit.interestConcepts?.length > 0 && (
            <div class="lp-modal__block">
              <p class="lp-modal__block-label">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M7 1l1.5 4h4.5l-3.5 2.5 1.5 4L7 9 3 11.5l1.5-4L1 5h4.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                </svg>
                Conceptos de interés
              </p>
              <ul class="lp-modal__list lp-modal__list--interest">
                {unit.interestConcepts.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          )}

        </div>

        <button class="lp-modal__close" aria-label="Cerrar" data-close>
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
      <div class="lp-modal__backdrop" data-close></div>
    </dialog>
  );
})}

<!-- ── Estilos ────────────────────────────────────────── -->
<style>
.lp-wrapper {
  position: relative;
  padding: 2rem 0 3rem;
}

.lp-svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: visible;
}

.lp-track {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 3.5rem;
}

.lp-node { display: flex; }
.lp-node--left  { justify-content: flex-start;  padding-left:  8%; }
.lp-node--right { justify-content: flex-end;     padding-right: 8%; }

/* ── Burbuja ── */
.lp-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.45rem;
  cursor: pointer;
  background: none;
  border: none;
  padding: 0;
  color: inherit;
  font: inherit;
}

.lp-bubble__num {
  width: 4.5rem;
  height: 4.5rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 2px solid var(--node-accent);
  background: var(--node-bg);
  backdrop-filter: blur(8px);
  font-family: "Fraunces", "Georgia", serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--node-accent);
  box-shadow:
    0 0 0 6px color-mix(in srgb, var(--node-accent) 10%, transparent),
    0 8px 24px color-mix(in srgb, var(--node-accent) 20%, transparent);
  transition: transform 250ms var(--ease-fluid), box-shadow 250ms var(--ease-fluid);
}

.lp-bubble__label {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--text-soft);
  text-align: center;
  max-width: 8rem;
  line-height: 1.25;
  transition: color 200ms var(--ease-fluid);
}

.lp-bubble__sub {
  font-size: 0.72rem;
  color: var(--text-muted);
  text-align: center;
  max-width: 9rem;
  line-height: 1.3;
}

.lp-bubble:hover .lp-bubble__num,
.lp-bubble:focus-visible .lp-bubble__num {
  transform: scale(1.12);
  box-shadow:
    0 0 0 10px color-mix(in srgb, var(--node-accent) 14%, transparent),
    0 12px 32px color-mix(in srgb, var(--node-accent) 30%, transparent);
}
.lp-bubble:hover .lp-bubble__label { color: var(--node-accent); }
.lp-bubble:focus-visible .lp-bubble__num {
  outline: 2px solid var(--node-accent);
  outline-offset: 4px;
}

/* ── Modal ── */
.lp-modal {
  position: fixed;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 1rem;
  background: none;
  border: none;
  z-index: 100;
  max-width: none;
  max-height: none;
  width: 100%;
  height: 100%;
}
.lp-modal[open] { display: flex; }

.lp-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(8, 17, 31, 0.72);
  backdrop-filter: blur(6px);
  cursor: pointer;
}

.lp-modal__inner {
  position: relative;
  z-index: 1;
  width: min(580px, 100%);
  max-height: 90vh;
  overflow-y: auto;
  background: linear-gradient(
    160deg,
    color-mix(in srgb, var(--surface)   92%, transparent),
    color-mix(in srgb, var(--surface-2) 96%, transparent)
  );
  border: 1px solid var(--line-strong);
  border-radius: var(--radius-2xl);
  padding: 2.2rem;
  box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,0.06);
  animation: modalIn 320ms var(--ease-fluid) both;
}

@keyframes modalIn {
  from { opacity: 0; transform: translateY(14px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* scrollbar sutil */
.lp-modal__inner::-webkit-scrollbar { width: 4px; }
.lp-modal__inner::-webkit-scrollbar-track { background: transparent; }
.lp-modal__inner::-webkit-scrollbar-thumb {
  background: color-mix(in srgb, var(--node-accent) 40%, transparent);
  border-radius: 99px;
}

.lp-modal__header {
  margin-bottom: 1.4rem;
  padding-bottom: 1.2rem;
  border-bottom: 1px solid var(--line);
}

.lp-modal__eyebrow {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--node-accent);
  background: var(--node-bg);
  padding: 0.3rem 0.75rem;
  border-radius: 999px;
  margin-bottom: 0.75rem;
  border: 1px solid color-mix(in srgb, var(--node-accent) 35%, transparent);
}

.lp-modal__title {
  font-size: clamp(1.15rem, 2.5vw, 1.5rem);
  margin: 0 0 0.35rem;
  color: var(--text);
}

.lp-modal__subtitle {
  margin: 0;
  color: var(--text-muted);
  font-size: 0.91rem;
}

/* ── Bloques del modal ── */
.lp-modal__body {
  display: grid;
  gap: 1.4rem;
}

.lp-modal__block {
  display: grid;
  gap: 0.6rem;
}

.lp-modal__block-label {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  margin: 0;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--node-accent);
}

.lp-modal__reflection {
  margin: 0;
  color: var(--text-soft);
  line-height: 1.72;
  font-size: 0.95rem;
}

.lp-modal__list {
  margin: 0;
  padding: 0;
  list-style: none;
  display: grid;
  gap: 0.38rem;
}

.lp-modal__list li {
  position: relative;
  padding-left: 1.3rem;
  color: var(--text-soft);
  font-size: 0.93rem;
  line-height: 1.5;
}

.lp-modal__list li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.58rem;
  width: 0.42rem;
  height: 0.42rem;
  border-radius: 50%;
  background: var(--node-accent);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--node-accent) 20%, transparent);
}

/* Interés: marcador diferente (rombo) */
.lp-modal__list--interest li::before {
  border-radius: 2px;
  transform: rotate(45deg);
}

.lp-modal__close {
  position: absolute;
  top: 1.1rem;
  right: 1.1rem;
  width: 2.1rem;
  height: 2.1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: color-mix(in srgb, var(--surface-3) 80%, transparent);
  border: 1px solid var(--line);
  border-radius: 999px;
  cursor: pointer;
  color: var(--text-muted);
  transition: color 180ms, background 180ms, transform 180ms var(--ease-fluid);
  font: inherit;
}
.lp-modal__close:hover {
  color: var(--text);
  background: color-mix(in srgb, var(--surface-2) 95%, transparent);
  transform: scale(1.1);
}

/* ── Responsive ── */
@media (min-width: 760px) {
  .lp-node--left  { padding-left:  18%; }
  .lp-node--right { padding-right: 18%; }
  .lp-bubble__num { width: 5.5rem; height: 5.5rem; font-size: 1.8rem; }
  .lp-bubble__label { font-size: 0.87rem; max-width: 9rem; }
}

@media (prefers-reduced-motion: reduce) {
  .lp-modal__inner { animation: none; }
}
</style>

<!-- ── Script ─────────────────────────────────────────── -->
<script>
(function () {
  function drawPath() {
    const svg = document.querySelector(".lp-svg");
    const poly = document.getElementById("lp-polyline");
    const nodes = document.querySelectorAll(".lp-bubble__num");
    if (!svg || !poly || nodes.length === 0) return;
    const svgRect = svg.getBoundingClientRect();
    const points = Array.from(nodes).map((el) => {
      const r = el.getBoundingClientRect();
      return { x: r.left + r.width / 2 - svgRect.left, y: r.top + r.height / 2 - svgRect.top };
    });
    poly.setAttribute("points", points.map((p) => `${p.x},${p.y}`).join(" "));
  }

  drawPath();
  window.addEventListener("resize", drawPath);

  function openModal(id: string) {
    const modal = document.getElementById(id) as HTMLDialogElement | null;
    if (!modal) return;
    modal.showModal ? modal.showModal() : ((modal as any).open = true);
    document.body.style.overflow = "hidden";
    (modal.querySelector("button") as HTMLElement | null)?.focus();
  }

  function closeModal(modal: HTMLDialogElement) {
    modal.close ? modal.close() : ((modal as any).open = false);
    document.body.style.overflow = "";
  }

  document.querySelectorAll<HTMLButtonElement>(".lp-bubble[data-modal]").forEach((btn) => {
    btn.addEventListener("click", () => openModal(btn.dataset.modal!));
  });

  document.querySelectorAll<HTMLDialogElement>(".lp-modal").forEach((modal) => {
    modal.querySelectorAll("[data-close]").forEach((el) => {
      el.addEventListener("click", () => closeModal(modal));
    });
    modal.addEventListener("cancel", (e) => { e.preventDefault(); closeModal(modal); });
  });
})();
</script>