---
import { closingReflection, siteMeta } from "../data/content";
---

<footer class="site-footer">
  <div class="container footer-wrap">
    <div>
      <p class="footer-title">{siteMeta.teamName}</p>
      <p>{siteMeta.description}</p>
    </div>
    <div class="footer-closing">
      <p class="footer-title">{closingReflection.title}</p>
      <p class="footer-note">{closingReflection.detail}</p>
    </div>
  </div>
</footer>
