---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
---

<header class={`section-heading section-heading--${align} reveal-up`} data-reveal>
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  {description && <p>{description}</p>}
</header>
