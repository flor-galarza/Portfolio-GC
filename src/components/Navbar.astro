---
import teamLogo from "../assets/logo.png";
import { navLinks, siteMeta } from "../data/content";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const isCurrent = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<header class="site-header" data-navbar>
  <div class="container nav-wrap">
    <a href="/" class="brand">
      <img src={teamLogo.src} alt="" class="" width="60" height="60" aria-hidden="true" />
      <span class="gap-2">
        <strong class="opacity-85">{siteMeta.teamName}</strong>
        <small>{siteMeta.teamLabel}</small>
      </span>
    </a>

    <button class="mobile-menu-button" data-mobile-menu-button aria-expanded="false" aria-label="Abrir menu principal">
      Menu
    </button>

    <nav class="nav-desktop" aria-label="Principal">
      <ul>
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class={isCurrent(link.href) ? "active" : ""}>{link.label}</a>
          </li>
        ))}
      <li>
        <a href="/desafios" class={currentPath.startsWith("/desafios") ? "active" : ""}>Desafios</a>

  <nav class="nav-mobile" aria-label="Principal movil" data-mobile-menu>
    <ul>
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class={isCurrent(link.href) ? "active" : ""}>{link.label}</a>
        </li>
      ))}
      <li>
        <a href="/desafios" class={currentPath.startsWith("/desafios") ? "active" : ""}>Desafios</a>
      </li>
      <li>
        <button class="theme-toggle" data-theme-toggle type="button" aria-pressed="true">Tema: Oscuro</button>
      </li>
    </ul>
  </nav>
</header>

<script>
  const navbar = document.querySelector("[data-navbar]") as HTMLElement;
  let lastY = window.scrollY;

  window.addEventListener("scroll", () => {
    const currentY = window.scrollY;
    if (currentY > lastY && currentY > 80) {
      navbar.style.transform = "translateY(-100%)";
    } else {
      navbar.style.transform = "translateY(0)";
    }
    lastY = currentY;
  }, { passive: true });
</script>
