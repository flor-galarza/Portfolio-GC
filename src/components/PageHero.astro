---
interface Action {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  actions?: Action[];
  compact?: boolean;
}

const { eyebrow, title, description, actions = [], compact = false } = Astro.props;
---

<section class={`page-section ${compact ? "hero-compact" : "hero"}`}>
  <div class="container hero-block reveal-up" data-reveal>
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="hero-lead hero-lead--wide">{description}</p>
    {actions.length > 0 && (
      <div class="hero-actions">
        {actions.map((action) => (
          <a class={`button ${action.variant === "secondary" ? "button-secondary" : "button-primary"}`} href={action.href}>
            {action.label}
          </a>
        ))}
      </div>
    )}
  </div>
</section>
