---
import Card from "./Card.astro";
import Badge from "./Badge.astro";
import EvidenceList from "./EvidenceList.astro";
import PageHero from "./PageHero.astro";
import SectionHeader from "./SectionHeader.astro";
import type { Challenge } from "../data/content";

interface Props {
  challenge: Challenge;
}

const { challenge } = Astro.props;
const isUpcoming = challenge.status === "upcoming";
---

<PageHero
  eyebrow={`Desafío ${challenge.code}`}
  title={challenge.title}
  description={challenge.summary}
  actions={[
    { href: "/desafios", label: "Volver al recorrido", variant: "secondary" },
    { href: "/tpi", label: "Ver conexión con el TPI" }
  ]}
  compact
/>

{isUpcoming && (
  <section class="page-section section-shell">
    <div class="container">
      <Card title="Estado de la etapa" subtitle="Contenido reservado para una próxima entrega">
        <p>
          Esta página mantiene la estructura definitiva del sitio, pero todavía no publica avances inexistentes. Cuando el desafío se
          desarrolle, este espacio podrá actualizarse con información real sin cambiar la UX general.
        </p>
      </Card>
    </div>
  </section>
)}

<section class="page-section section-shell">
  <div class="container split-grid split-grid--feature">
    <Card title={isUpcoming ? "Estado actual" : "Problema abordado"} subtitle={isUpcoming ? "Qué se sabe hoy sobre esta etapa" : "Qué necesitaba resolver el equipo"}>
      <p>{challenge.problem}</p>
    </Card>
    <Card title={isUpcoming ? "Preparación del espacio" : "Solución propuesta"} subtitle={isUpcoming ? "Cómo quedará lista la página para su publicación futura" : "Cómo se respondió al desafío"}>
      <p>{challenge.solution}</p>
    </Card>
  </div>
</section>

<section class="page-section section-shell">
  <div class="container">
    <SectionHeader
      eyebrow="Evidencias"
      title={isUpcoming ? "Documentos, presentaciones, videos y respaldos" : "Micrositio publicado y respaldos del proceso"}
      description={
        isUpcoming
          ? "Si falta el material definitivo, el sitio deja placeholders claros y elegantes para reemplazarlos después sin romper la experiencia."
          : "En este desafío no hacen falta placeholders de presentación o galería: la propia publicación del micrositio ya funciona como evidencia principal, acompañada por sus respaldos documentales."
      }
    />
    <EvidenceList items={challenge.evidences} />
  </div>
</section>

<section class="page-section section-shell">
  <div class="container split-grid split-grid--feature">
    <Card title={isUpcoming ? "Qué se completará aquí" : "Herramientas utilizadas"} subtitle={isUpcoming ? "Frentes previstos para documentar cuando la etapa comience" : "Tecnologías, gestión y soportes de trabajo"}>
      <div class="badge-row">
        {challenge.tools.map((tool) => (
          <Badge label={tool} />
        ))}
      </div>
    </Card>
    <Card title="Conexión con el TPI" subtitle={isUpcoming ? "Cómo se integrará esta etapa cuando exista contenido real" : "Por qué este desafío importa en el recorrido global"}>
      <p>{challenge.tpiConnection}</p>
    </Card>
  </div>
</section>

<section class="page-section section-shell">
  <div class="container">
    <SectionHeader
      eyebrow="Reflexión del equipo"
      title={isUpcoming ? "Notas preparadas para futuras iteraciones" : "Aprendizajes, mejoras y competencias desarrolladas"}
      description={isUpcoming ? "La experiencia mantiene la misma jerarquía visual sin inventar aprendizajes todavía no obtenidos." : "Cada desafío deja una lectura crítica que conecta proceso, resultado y evolución del equipo."}
    />
    <div class="card-grid card-grid--reflections">
      {challenge.learnings.map((reflection) => (
        <Card title={reflection.title}>
          <p>{reflection.detail}</p>
        </Card>
      ))}
    </div>
  </div>
</section>

<section class="page-section section-shell">
  <div class="container split-grid split-grid--feature">
    <Card title={isUpcoming ? "Qué se definirá más adelante" : "Qué haríamos distinto"} subtitle={isUpcoming ? "Pendientes editoriales para completar esta etapa" : "Oportunidades de mejora para próximas iteraciones"}>
      <ul class="clean-list clean-list--tight">
        {challenge.wouldDoDifferent.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </Card>
    <Card title={isUpcoming ? "Competencias a documentar" : "Competencias desarrolladas"} subtitle={isUpcoming ? "Se completarán cuando el desafío tenga trabajo real publicado" : "Capacidades reforzadas en el proceso"}>
      <div class="badge-row">
        {challenge.competenciesDeveloped.map((item) => (
          <Badge label={item} />
        ))}
      </div>
    </Card>
  </div>
</section>
