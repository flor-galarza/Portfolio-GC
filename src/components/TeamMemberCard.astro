---
import Badge from "./Badge.astro";
import type { TeamMember } from "../data/content";

interface Props {
  member: TeamMember;
  compact?: boolean;
}

const { member, compact = false } = Astro.props;
const profileGroups = [
  { label: "Intereses", items: member.interests },
  { label: "Competencias", items: member.competencies }
] as const;
---

<a class="profile-link" href={`/equipo/${member.id}`}>
  <article class={`profile-card reveal-up ${compact ? "profile-card--compact" : ""}`} data-reveal>
    <div class={`profile-card__photo profile-photo--${member.accent}`}>
      {member.avatar ? (
        <img src={member.avatar} alt={member.name} loading="lazy" decoding="async" />
      ) : (
        <span class="profile-card__initials">{member.initials}</span>
      )}
    </div>

    <div class="profile-card__body">
      <p class="profile-kicker">{member.role}</p>
      <h3>{member.name}</h3>
      {!compact && <p class="profile-tagline">{member.tagline}</p>}
      <p class="profile-bio">{member.bio}</p>

      {!compact &&
        profileGroups.map((group) => (
          <div class="profile-group">
            <p class="list-label">{group.label}</p>
            <div class="badge-row">
              {group.items.map((item) => (
                <Badge label={item} />
              ))}
            </div>
          </div>
        ))}

      {!compact && member.note && <p class="support-note profile-note">{member.note}</p>}

      {!compact && (
        <div class="profile-group">
          <p class="list-label">Aporte al TPI</p>
          <p>{member.contribution}</p>
        </div>
      )}
    </div>
  </article>
</a>
